# 背景
[manager]
cwd = { fg = "#c8c8c8" }

# 檔案列表
[manager.file]
fg = "#d8d8d8"

# 選取
[manager.selection]
fg = "#d8d8d8"
bg = "#111111"

# hovered（游標所在）
[manager.hovered]
fg = "#ffffff"
bg = "#111111"

# inactive（灰）
[manager.inactive]
fg = "#707070"

# directory
[manager.directory]
fg = "#7aa2f7"

# symlink
[manager.symlink]
fg = "#56b6c2"

# executable
[manager.executable]
fg = "#98c379"

# archive
[manager.archive]
fg = "#e5c07b"

# border
[border]
fg = "#303030"

# preview
[preview]
fg = "#d8d8d8"
bg = "#000000"
